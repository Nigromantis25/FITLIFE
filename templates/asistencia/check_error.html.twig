{% extends 'layouts/base.html.twig' %}

{% block title %}Error | FitLife{% endblock %}

{% block body %}
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#070707;padding:20px;">
  <div style="text-align:center;background:#1a1a1a;padding:40px;border-radius:12px;max-width:400px;border:2px solid #ff4d4d;">
    <div style="font-size:56px;margin-bottom:20px;">
      ❌
    </div>
    
    <h1 style="font-family:'Bebas Neue',sans-serif;font-size:32px;margin-bottom:20px;color:#ff8080;">
      ERROR
    </h1>
    
    <div style="background:#0a0c12;padding:20px;border-radius:8px;margin-bottom:30px;">
      <p style="color:#ff8080;font-size:16px;">
        {{ error }}
      </p>
    </div>
    
    <a href="/panel-gimnasio" style="display:inline-block;background:#1e2230;color:#58a6ff;padding:12px 24px;border-radius:6px;text-decoration:none;border:1px solid #58a6ff;">
      Volver al panel
    </a>
  </div>
</div>
{% endblock %}
