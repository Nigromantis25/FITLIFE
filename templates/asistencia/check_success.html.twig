{% extends 'layouts/base.html.twig' %}

{% block title %}Entrada/Salida Registrada | FitLife{% endblock %}

{% block body %}
<div style="min-height:100vh;display:flex;align-items:center;justify-content:center;background:#070707;padding:20px;">
  <div style="text-align:center;background:#1a1a1a;padding:40px;border-radius:12px;max-width:400px;border:2px solid #4cff4c;">
    <div style="font-size:56px;margin-bottom:20px;">
      {% if tipo == 'entrada' %}
        ✅
      {% else %}
        👋
      {% endif %}
    </div>
    
    <h1 style="font-family:'Bebas Neue',sans-serif;font-size:32px;margin-bottom:10px;color:#4cff4c;">
      {% if tipo == 'entrada' %}
        BIENVENIDO
      {% else %}
        HASTA LUEGO
      {% endif %}
    </h1>
    
    <div style="font-size:28px;color:#e8e8e8;margin-bottom:30px;">
      {{ cliente.nombre }} {{ cliente.apellido }}
    </div>
    
    <div style="background:#0a0c12;padding:20px;border-radius:8px;margin-bottom:30px;">
      <div style="color:#bbb;font-size:12px;margin-bottom:10px;">
        {% if tipo == 'entrada' %}
          HORA DE ENTRADA
        {% else %}
          HORA DE SALIDA
        {% endif %}
      </div>
      <div style="font-size:48px;color:#58a6ff;font-family:monospace;font-weight:bold;">
        {{ hora }}
      </div>
    </div>
    
    <p style="color:#999;font-size:14px;">
      Redirigiendo en 5 segundos...
    </p>
  </div>
</div>

<script>
  setTimeout(() => {
    window.location.href = '/panel-gimnasio';
  }, 5000);
</script>
{% endblock %}
