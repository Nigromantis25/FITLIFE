{% extends 'layouts/base.html.twig' %}

{% block title %}Panel de Asistencias y Reportes | FitLife{% endblock %}

{% block body %}
<section style="min-height:100vh;padding:80px 20px;background:#070707;color:#f5f5f5;">
  <div style="max-width:960px;margin:0 auto;text-align:center;">
    <h1 style="font-family:'Bebas Neue',sans-serif;font-size:48px;margin-bottom:16px;">Panel del Gimnasio</h1>
    <p style="color:#d3d3d3;font-size:18px;margin-bottom:40px;">Accede a asistencias, reportes y el dashboard de control para tu equipo.</p>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:20px;">
      <a href="{{ path('recepcionista_dashboard') }}" class="btn-primary" style="display:flex;justify-content:center;align-items:center;height:120px;">Dashboard</a>
      <a href="{{ path('recepcionista_asistencias') }}" class="btn-primary" style="display:flex;justify-content:center;align-items:center;height:120px;">Asistencias</a>
      <a href="{{ path('recepcionista_reportes') }}" class="btn-primary" style="display:flex;justify-content:center;align-items:center;height:120px;">Reportes</a>
    </div>

    <p style="margin-top:24px;color:#aaaaaa;font-size:14px;">* Requiere iniciar sesión como recepcionista o admin para ver datos reales</p>
  </div>
</section>
{% endblock %}
