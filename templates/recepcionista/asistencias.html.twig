{% extends 'layouts/recepcionista.html.twig' %}

{% block title %}Asistencias | Recepcionista{% endblock %}

{% block content %}
  <h2>Registro de Asistencias</h2>
  <table style="width:100%;border-collapse:collapse;margin-top:20px;">
    <thead>
      <tr style="background:#222;color:#fff;">
        <th style="padding:10px;border:1px solid #333;">Cliente</th>
        <th style="padding:10px;border:1px solid #333;">Fecha</th>
        <th style="padding:10px;border:1px solid #333;">Entrada</th>
        <th style="padding:10px;border:1px solid #333;">Salida</th>
      </tr>
    </thead>
    <tbody>
      {% for item in asistencias %}
      <tr style="border:1px solid #333;">
        <td style="padding:10px;border:1px solid #333;">{{ item.cliente }}</td>
        <td style="padding:10px;border:1px solid #333;">{{ item.fecha }}</td>
        <td style="padding:10px;border:1px solid #333;">{{ item.entrada }}</td>
        <td style="padding:10px;border:1px solid #333;">{{ item.salida }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
{% endblock %}
